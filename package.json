{
  "name": "gym-seyssin",
  "version": "0.1.0",
  "private": true,
  "description": "Site vitrine de l'association Gym Multisport de Seyssins",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typegen:extract": "sanity schema extract --workspace gym-seyssins --enforce-required-fields",
    "typegen:generate": "sanity typegen generate",
    "typegen": "pnpm typegen:extract && pnpm typegen:generate"
  },
  "pnpm": {
    "overrides": {
      "@portabletext/sanity-bridge": "1.2.14"
    }
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^4.22.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "^15.5.15",
    "next-sanity": "^12.4.2",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19",
    "react-dom": "^19",
    "sanity": "^4.22.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "styled-components": "^6.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@sanity/types": "^4.22.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.5.15",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
