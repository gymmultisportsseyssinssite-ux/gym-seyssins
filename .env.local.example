# =====================================================================
# Gym Multisport Seyssins — variables d'environnement
# Copier ce fichier en .env.local et compléter les valeurs.
# Ne jamais committer .env.local.
# =====================================================================

# ---------- Site ----------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- Sanity ----------
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-01
# Token lecture (drafts / contenu privé). À créer dans Sanity Manage > API.
SANITY_API_READ_TOKEN=
# UUID v4 — protège le webhook /api/revalidate. À recopier dans Sanity Manage > Webhooks.
SANITY_REVALIDATE_SECRET=

# ---------- Resend (formulaire de contact) ----------
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Gym Seyssins <noreply@gym-seyssin.fr>
# RESEND_TO_EMAIL=contact@gym-seyssin.fr

# ---------- Vercel / divers ----------
# Variables fournies automatiquement par Vercel — ne pas surcharger en local.
